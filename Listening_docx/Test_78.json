      "section_name": "Part 3: Questions 21-30",
      "instruction": "Choose the correct letter A, B or C.",
      "passage_or_context": "Study on Gender in Physics",
      "questions": [
        {
          "q_numbers": "21",
          "type": "multiple_choice",
          "content": "The students in Akira Miyake\u2019s study were all majoring in",
          "options": [
            "physics",
            "psychology or physics",
            "science, technology, engineering or mathematics"
          ]
        },
        {
          "q_numbers": "22",
          "type": "multiple_choice",
          "content": "The aim of Miyake\u2019s study was to investigate",
          "options": [
            "what kind of women choose to study physics",
            "a way of improving women\u2019s performance in physics",
            "whether fewer women than men study physics at college"
          ]
        },
        {
          "q_numbers": "23",
          "type": "multiple_choice",
          "content": "The female physics students were wrong to believe that",
          "options": [
            "the teachers marked them in an unfair way",
            "the male students expected them to do badly",
            "their test results were lower than the male students\u2019"
          ]
        },
        {
          "q_numbers": "24",
          "type": "multiple_choice",
          "content": "Miyake\u2019s team asked the students to write about",
          "options": [
            "what they enjoyed about studying physics",
            "the successful experiences of other people",
            "something that was important to them personally"
          ]
        },
        {
          "q_numbers": "25",
          "type": "multiple_choice",
          "content": "What was the aim of the writing exercise done by the subjects?",
